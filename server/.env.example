# Backend do Blog - Variables de Ambiente
# Copie este arquivo para .env e preencha com seus valores

# Porta do servidor
PORT=3001

# String de conexão do MongoDB
# Para MongoDB local:
MONGODB_URI=mongodb://localhost:27017/al-profile-blog

# Para MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://<usuario>:<senha>@cluster.mongodb.net/al-profile-blog

# Chave secreta para JWT (gere uma chave aleatória segura)
JWT_SECRET=sua_chave_secreta_muito_segura_aqui_32_chars

# Email que recebera as notificacoes dos contatos do site
CONTACT_NOTIFICATION_TO=contato@adriano-lengruber.com

# SMTP do provedor de email (ex.: Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contato@adriano-lengruber.com
SMTP_PASS=sua_senha_smtp
SMTP_FROM_EMAIL=contato@adriano-lengruber.com
SMTP_FROM_NAME=Site Adriano Lengruber
